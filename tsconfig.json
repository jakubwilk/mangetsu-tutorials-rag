{
  "compilerOptions": {
    "target": "ES2017",
    "lib": ["dom", "dom.iterable", "esnext"],
    "allowJs": true,
    "skipLibCheck": true,
    "strict": true,
    "noEmit": true,
    "esModuleInterop": true,
    "module": "esnext",
    "moduleResolution": "bundler",
    "resolveJsonModule": true,
    "isolatedModules": true,
    "jsx": "react-jsx",
    "incremental": true,
    "plugins": [
      {
        "name": "next"
      }
    ],
    "paths": {
      "@/*": ["./src/*"],
      "app/*": ["./src/app/*"],
      "chat": ["./src/components/chat/index"],
      "chat/*": ["./src/components/chat/*"],
      "layout": ["./src/components/layout/index"],
      "layout/*": ["./src/components/layout/*"],
      "notices": ["./src/components/notices/index"],
      "notices/*": ["./src/components/notices/*"],
      "data/*": ["./src/data/*"],
      "lib": ["./src/lib/index"],
      "lib/*": ["./src/lib/*"],
      "store": ["./src/store/index"],
      "store/*": ["./src/store/*"]
    }
  },
  "include": [
    "next-env.d.ts",
    "**/*.ts",
    "**/*.tsx",
    ".next/types/**/*.ts",
    ".next/dev/types/**/*.ts",
    "**/*.mts"
  ],
  "exclude": ["node_modules"]
}
